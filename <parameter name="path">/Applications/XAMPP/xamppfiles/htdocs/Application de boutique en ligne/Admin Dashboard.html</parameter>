<parameter name="content"><!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' https:;">
  <title>Dashboard - Gestion des Produits</title>
  <link rel="stylesheet" href="style_dashboard.css">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <button class="theme-toggle" onclick="toggleTheme()"><span id="themeIcon">🌙</span></button>
  <nav class="sidebar" aria-label="Sidebar menu">
    <h3>🛒 Mon Dashboard</h3>
    <button type="button" onclick="showAddProductForm()"><i class="bx bx-plus-circle"></i> Ajouter un Produit</button>
    <button type="button" onclick="afficherFormulaire('afficher')"><i class='bx bx-list-ul'></i> Voir les Produits</button>
    <button type="button" onclick="showHiddenProducts()"><i class="bx bx-hide"></i> Produits Cachés</button>
    <button type="button" onclick="showLogoutPopup()"><i class="bx bx-log-out"></i> Se déconnecter</button>
  </nav>
  <main class="dashboard" role="main">
    <section aria-label="Real-time statistics" class="stats-section">
      <h2 class="section-title">📊 Statistiques en Temps Réel</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon">📦</div>
          <div class="stat-info">
            <h3>Total Produits</h3>
            <p class="stat-value" id="statTotalProducts">0</p>
          </div>
        <div class="stat-card">
          <div class="stat-icon">⚠️</div>
          <div class="stat-info">
            <h3>Stock Faible</h3>
            <p class="stat-value" id="statLowStock">0</p>
          </div>
        <div class="stat-card">
          <div class="stat-icon">❌</div>
          <div class="stat-info">
            <h3>Rupture Stock</h3>
            <p class="stat-value" id="statOutOfStock">0</p>
          </div>
        <div class="stat-card">
          <div class="stat-icon">🏷️</div>
          <div class="stat-info">
            <h3>Total Stock</h3>
            <p class="stat-value" id="statTotalStock2">0</p>
          </div>
      </div>
      <button class="btn-refresh" onclick="refreshStats()">🔄 Actualiser</button>
    </section>

    <section aria-label="Summary metrics" class="card-container">
      <article class="card">
        <div class="icon">📦</div>
        <h3>Total Produits</h3>
        <p><span id="total">0</span></p>
      </article>
      <article class="card">
        <div class="icon">📱</div>
        <h3>Tech</h3>
        <p><span id="tech">0</span></p>
      </article>
      <article class="card">
        <div class="icon">💄</div>
        <h3>Beauté</h3>
        <p><span id="beauty">0</span></p>
      </article>
      <article class="card">
        <div class="icon">🏠</div>
        <h3>Maison</h3>
        <p><span id="goods">0</span></p>
      </article>
      <article class="card">
        <div class="icon">👔</div>
        <h3>Mode</h3>
        <p><span id="fashion">0</span></p>
      </article>
      <article class="card">
        <div class="icon">⌚</div>
        <h3>Accessoires</h3>
        <p><span id="accessories">0</span></p>
      </article>
    </section>

    <section id="addProductSection" style="display:none;">
      <h2 class="section-title">✨ Ajouter un Nouveau Produit</h2>
      <form id="addProductForm" onsubmit="addProduct(event)">
        <div class="form-row">
          <div class="form-group">
            <label>Nom du Produit *</label>
            <input type="text" id="productName" required placeholder="Nom du produit">
          </div>
          <div class="form-group">
            <label>Catégorie *</label>
            <select id="productCategory" required>
              <option value="">Sélectionner</option>
              <option value="tech">📱 Tech</option>
              <option value="beauty">💄 Beauté</option>
              <option value="goods">🏠 Maison</option>
              <option value="fashion">👔 Mode</option>
              <option value="accessories">⌚ Accessoires</option>
            </select>
          </div>
        <div class="form-group">
          <label>Description</label>
          <textarea id="productDescription" rows="3" placeholder="Description..."></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Prix (FCFA) *</label>
            <input type="number" id="productPrice" required min="0" placeholder="0">
          </div>
          <div class="form-group">
            <label>Ancien Prix</label>
            <input type="number" id="productOldPrice" min="0" placeholder="0">
          </div>
        <div class="form-row">
          <div class="form-group">
            <label>Stock *</label>
            <input type="number" id="productStock" required min="0" placeholder="0">
          </div>
          <div class="form-group">
            <label>Note (1-5)</label>
            <input type="number" id="productRating" min="1" max="5" step="0.1" placeholder="0-5">
          </div>
        <div class="form-group">
          <label>URL Image</label>
          <input type="url" id="productImage" placeholder="https://exemple.com/image.jpg">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Badge</label>
            <input type="text" id="productBadge" placeholder="Nouveau, Sale...">
          </div>
          <div class="form-group">
            <label>En vedette</label>
            <select id="productFeatured">
              <option value="0">Non</option>
              <option value="1">Oui</option>
            </select>
          </div>
        <div class="form-buttons">
          <button type="submit" class="btn-primary">➕ Ajouter</button>
          <button type="button" class="btn-secondary" onclick="hideAddProductForm()">✖️ Annuler</button>
        </div>
      </form>
    </section>

    <section id="productsSection" style="display:none;">
      <h2 class="section-title">📋 Liste des produits</h2>
      <input id="searchInput" type="search" placeholder="🔍 Rechercher..." />
      <div class="table-container">
        <table id="dataTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Image</th>
              <th>Nom</th>
              <th>Prix</th>
              <th>Catégorie</th>
              <th>Stock</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </section>

    <section id="hiddenProductsSection" style="display:none;">
      <h2 class="section-title">🙈 Produits Cachés</h2>
      <div class="table-container">
        <table id="hiddenDataTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Image</th>
              <th>Nom</th>
              <th>Prix</th>
              <th>Stock</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </section>
  </main>

  <div id="editModal" style="display:none;">
    <div>
      <h2>✏️ Modifier le Produit</h2>
      <form id="editProductForm" onsubmit="saveProductEdit(event)">
        <input type="hidden" id="editProductId">
        <div class="form-row">
          <div class="form-group">
            <label>Nom *</label>
            <input type="text" id="editName" required>
          </div>
          <div class="form-group">
            <label>Catégorie *</label>
            <select id="editCategory" required>
              <option value="tech">📱 Tech</option>
              <option value="beauty">💄 Beauté</option>
              <option value="goods">🏠 Maison</option>
              <option value="fashion">👔 Mode</option>
              <option value="accessories">⌚ Accessoires</option>
            </select>
          </div>
        <div class="form-group">
          <label>Description</label>
          <textarea id="editDescription" rows="2"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Prix (FCFA) *</label>
            <input type="number" id="editPrice" required min="0">
          </div>
          <div class="form-group">
            <label>Ancien Prix</label>
            <input type="number" id="editOldPrice" min="0">
          </div>
        <div class="form-row">
          <div class="form-group">
            <label>Stock *</label>
            <input type="number" id="editStock" required min="0">
          </div>
          <div class="form-group">
            <label>Note</label>
            <input type="number" id="editRating" min="1" max="5" step="0.1">
          </div>
        <div class="form-group">
          <label>URL Image</label>
          <input type="url" id="editImage">
        </div>
        <div class="form-buttons">
          <button type="submit" class="btn-primary">💾 Enregistrer</button>
          <button type="button" class="btn-secondary" onclick="closeEditModal()">✖️ Annuler</button>
        </div>
      </form>
    </div>

  <div id="modalOverlay">
    <div id="modalContent">
      <h3>🚪 Confirmer la déconnexion</h3>
      <p>Voulez-vous vraiment vous déconnecter ?</p>
      <div id="modalButtons">
        <button class="btn-primary" onclick="window.location.href='index.html'">Oui</button>
        <button class="btn-secondary" onclick="hideLogoutPopup()">Annuler</button>
      </div>
  </div>

  <div id="messageBox" style="display:none;"></div>

  <script>
    const API_URL = './api.php';
    let products = [];
    const tbody = document.querySelector("#dataTable tbody");
    const hiddenTableBody = document.querySelector("#hiddenDataTable tbody");
    const productsSection = document.getElementById("productsSection");
    const addProductSection = document.getElementById("addProductSection");
    const searchInput = document.getElementById("searchInput");

    async function init() {
      loadTheme();
      await loadProductsFromDatabase();
      updateAllCounters();
    }

    async function loadProductsFromDatabase() {
      try {
        const response = await fetch(API_URL + '?action=getProducts');
        const result = await response.json();
        if (result.success && result.data) {
          products = result.data.map(function(p) {
            return {
              id: p.id,
              name: p.name,
              description: p.description || p.desc,
              price: p.price,
              old_price: p.oldPrice || p.old_price,
              category: p.category,
              image: p.image,
              rating: p.rating,
              stock: p.stock,
              badge: p.badge,
              is_featured: p.isFeatured || p.is_featured,
              is_hidden: false
            };
          });
          localStorage.setItem('cachedProducts', JSON.stringify(products));
          console.log('Products loaded:', products.length);
        }
      } catch (e) {
        console.error('Database error:', e);
        const cached = localStorage.getItem('cachedProducts');
        if (cached) products = JSON.parse(cached);
      }
    }

    async function refreshStats() {
      await loadProductsFromDatabase();
      updateAllCounters();
      showMessage('Statistiques actualisées!', 'success');
    }

    function updateAllCounters() {
      document.getElementById("total").textContent = products.length;
      document.getElementById("tech").textContent = products.filter(function(p) { return p.category === 'tech'; }).length;
      document.getElementById("beauty").textContent = products.filter(function(p) { return p.category === 'beauty'; }).length;
      document.getElementById("goods").textContent = products.filter(function(p) { return p.category === 'goods'; }).length;
      document.getElementById("fashion").textContent = products.filter(function(p) { return p.category === 'fashion'; }).length;
      document.getElementById("accessories").textContent = products.filter(function(p) { return p.category === 'accessories'; }).length;
      
      document.getElementById('statTotalProducts').textContent = products.length;
      document.getElementById('statLowStock').textContent = products.filter(function(p) { return p.stock > 0 && p.stock < 10; }).length;
      document.getElementById('statOutOfStock').textContent = products.filter(function(p) { return !p.stock || p.stock === 0; }).length;
      document.getElementById('statTotalStock2').textContent = products.reduce(function(sum, p) { return sum + (p.stock || 0); }, 0);
    }

    function toggleTheme() {
      var html = document.documentElement;
      var icon = document.getElementById('themeIcon');
      if (html.getAttribute('data-theme') === 'dark') {
        html.setAttribute('data-theme', 'light');
        icon.textContent = '🌙';
        localStorage.setItem('theme', 'light');
      } else {
        html.setAttribute('data-theme', 'dark');
        icon.textContent = '☀️';
        localStorage.setItem('theme', 'dark');
      }
    }

    function loadTheme() {
      var savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
        document.getElementById('themeIcon').textContent = '☀️';
      }
    }

    function showAddProductForm() { 
      addProductSection.style.display = 'block'; 
      productsSection.style.display = 'none'; 
      document.getElementById('addProductForm').reset();
    }
    function hideAddProductForm() { addProductSection.style.display = 'none'; }

    function addProduct(event) {
      event.preventDefault();
      var newProduct = {
        id: products.length > 0 ? Math.max.apply(null, products.map(function(p) { return p.id; })) + 1 : 1,
        name: document.getElementById('productName').value,
        description: document.getElementById('productDescription').value,
        price: parseFloat(document.getElementById('productPrice').value),
        old_price: parseFloat(document.getElementById('productOldPrice').value) || null,
        category: document.getElementById('productCategory').value,
        stock: parseInt(document.getElementById('productStock').value),
        rating: parseFloat(document.getElementById('productRating').value) || 0,
        image: document.getElementById('productImage').value || 'https://via.placeholder.com/150',
        badge: document.getElementById('productBadge').value || null,
        is_featured: document.getElementById('productFeatured').value === '1',
        is_hidden: false
      };
      products.push(newProduct);
      showMessage('Produit ajouté!', 'success');
      document.getElementById('addProductForm').reset();
      updateAllCounters();
      setTimeout(function() { hideAddProductForm(); afficherFormulaire('afficher'); }, 1500);
    }

    function editProduct(id) {
      var product = products.find(function(p) { return p.id === id; });
      if (!product) return;
      document.getElementById('editProductId').value = id;
      document.getElementById('editName').value = product.name;
      document.getElementById('editCategory').value = product.category;
      document.getElementById('editDescription').value = product.description || '';
      document.getElementById('editPrice').value = product.price;
      document.getElementById('editOldPrice').value = product.old_price || '';
      document.getElementById('editStock').value = product.stock;
      document.getElementById('editRating').value = product.rating || '';
      document.getElementById('editImage').value = product.image || '';
      document.getElementById('editModal').style.display = 'block';
    }

    function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }

    function saveProductEdit(event) {
      event.preventDefault();
      var id = parseInt(document.getElementById('editProductId').value);
      var index = products.findIndex(function(p) { return p.id === id; });
      if (index !== -1) {
        products[index] = { 
          ...products[index], 
          name: document.getElementById('editName').value, 
          category: document.getElementById('editCategory').value, 
          description: document.getElementById('editDescription').value, 
          price: parseFloat(document.getElementById('editPrice').value), 
          old_price: parseFloat(document.getElementById('editOldPrice').value) || null, 
          stock: parseInt(document.getElementById('editStock').value), 
          rating: parseFloat(document.getElementById('editRating').value) || 0, 
          image: document.getElementById('editImage').value
        };
        showMessage('Produit modifié!', 'success');
        closeEditModal();
        displayProducts(products);
        updateAllCounters();
      }
    }

    function toggleProductVisibility(id) {
      var index = products.findIndex(function(p) { return p.id === id; });
      if (index !== -1) {
        products[index].is_hidden = !products[index].is_hidden;
        showMessage(products[index].is_hidden ? 'Produit caché!' : 'Produit affiché!', 'success');
        displayProducts(products);
        updateAllCounters();
      }
    }

    function deleteProduct(productId) {
      if (confirm("Êtes-vous sûr de vouloir supprimer ce produit?")) {
        products = products.filter(function(p) { return p.id != productId; });
        displayProducts(products);
        updateAllCounters();
        showMessage('Produit supprimé!', 'success');
      }
    }

    function showHiddenProducts() {
      addProductSection.style.display = 'none';
      productsSection.style.display = 'none';
      document.getElementById("hiddenProductsSection").style.display = 'block';
      displayHiddenProducts();
    }

    function displayHiddenProducts() {
      hiddenTableBody.innerHTML = "";
      var hiddenProducts = products.filter(function(p) { return p.is_hidden; });
      if (hiddenProducts.length === 0) {
        hiddenTableBody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;">Aucun produit caché</td></tr>';
        return;
      }
      hiddenProducts.forEach(function(product) {
        var row = document.createElement("tr");
        row.innerHTML = '<td>'+product.id+'</td><td><img src="'+product.image+'" alt="'+product.name+'" style="width:50px;height:50px;object-fit:cover;border-radius:8px;"></td><td>'+product.name+'</td><td>'+product.price.toLocaleString()+' FCA</td><td>'+product.stock+'</td><td><button class="btn-unhide" onclick="unhideProduct('+product.id+')">Afficher</button></td>';
        hiddenTableBody.appendChild(row);
      });
    }

    function unhideProduct(id) {
      var index = products.findIndex(function(p) { return p.id === id; });
      if (index !== -1) {
        products[index].is_hidden = false;
        showMessage('Produit affiché!', 'success');
        displayHiddenProducts();
        updateAllCounters();
      }
    }

    function displayProducts(productsToDisplay) {
      tbody.innerHTML = "";
      var visibleProducts = productsToDisplay.filter(function(p) { return !p.is_hidden; });
      if (visibleProducts.length === 0) { 
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;">Aucun produit</td></tr>'; 
        return; 
      }
      visibleProducts.forEach(function(product) {
        var stockClass = product.stock === 0 ? 'out-of-stock' : (product.stock < 10 ? 'low-stock' : 'in-stock');
        var row = document.createElement("tr");
        row.innerHTML = '<td>'+product.id+'</td><td><img src="'+product.image+'" alt="'+product.name+'" style="width:50px;height:50px;object-fit:cover;border-radius:8px;"></td><td>'+product.name+'</td><td style="font-weight:bold;">'+product.price.toLocaleString()+' FCA</td><td>'+product.category+'</td><td class="'+stockClass+'">'+product.stock+'</td><td><button class="btn-edit" onclick="editProduct('+product.id+')">Modifier</button><button class="btn-hide" onclick="toggleProductVisibility('+product.id+')">Cacher</button><button class="btn-delete" onclick="deleteProduct('+product.id+')">Supprimer</button></td>';
        tbody.appendChild(row);
      });
    }

    function filterProducts(term) {
      var filtered = products.filter(function(p) { 
        return !p.is_hidden && p.name.toLowerCase().includes(term); 
      });
      displayProducts(filtered);
    }

    searchInput.addEventListener("input", function(e) { filterProducts(e.target.value.trim().toLowerCase()); });

    function afficherFormulaire(formName) {
      if (formName.toLowerCase() === 'afficher') { 
        addProductSection.style.display = 'none'; 
        productsSection.style.display = 'block'; 
        searchInput.value = ""; 
        displayProducts(products); 
      }
    }

    function showMessage(message, type) { 
      var messageBox = document.getElementById('messageBox'); 
      messageBox.textContent = message; 
      messageBox.className = 'message-box ' + type; 
      messageBox.style.display = 'block'; 
      setTimeout(function() { messageBox.style.display = 'none'; }, 3000); 
    }
    
    function showLogoutPopup() { document.getElementById("modalOverlay").style.display = "flex"; }
    function hideLogoutPopup() { document.getElementById("modalOverlay").style.display = "none"; }
    
    window.addEventListener("DOMContentLoaded", init);
  </script>
</body>
</html></parameter>
